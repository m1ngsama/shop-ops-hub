APP_NAME="商运后台"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://shop.m1ng.space
APP_FORCE_HTTPS=true
APP_TIMEZONE=Asia/Shanghai
APP_KEY=base64:replace-this-with-a-real-key
APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=zh_CN
APP_FAKER_LOCALE=zh_CN

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=shop_ops_hub
DB_USERNAME=shop_ops_hub
DB_PASSWORD=change-this-app-password
DB_ROOT_PASSWORD=change-this-root-password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SHOP_OPS_ADMIN_EMAIL=admin@shop.m1ng.space
SHOP_OPS_ADMIN_PASSWORD=change-this-admin-password
SHOP_OPS_API_TOKEN=change-this-api-token

MAIL_MAILER=log
MAIL_FROM_ADDRESS=admin@shop.m1ng.space
MAIL_FROM_NAME="${APP_NAME}"
